generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Institution {
  id             String               @id @default(uuid())
  name           String
  slug           String               @unique
  type           InstitutionType      @default(school)
  plan           String               @default("basic")
  status         String               @default("active")
  phone          String?
  email          String?
  website        String?
  address        String?
  enabledModules String[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  assignments    Assignment[]
  attendance     Attendance[]
  auditLogs      AuditLog[]
  chatRooms      ChatRoom[]
  diaries        DailyDiary[]
  doubts         Doubt[]
  doubtReplies   DoubtReply[]
  exams          Exam[]
  examAttempts   ExamAttempt[]
  fees           FeeRecord[]
  feedbacks      FeedbackSubmission[]
  gradebooks     GradebookEntry[]
  settings       InstitutionSetting[]
  integrations   IntegrationConfig[]
  leaveRequests  LeaveRequest[]
  mcqQuestions   MCQQuestion[]
  notices        Notice[]
  notifLogs      NotificationLog[]
  onlineClasses  OnlineClass[]
  onlineExams    OnlineExam[]
  messages       ParentMessage[]
  payments       PaymentRecord[]
  payrolls       StaffPayroll[]
  supportStaff   SupportStaff[]
  syllabus       SyllabusUnit[]
  timetable      TimetablePeriod[]
  users          User[]
}

model User {
  id              String         @id @default(uuid())
  name            String
  email           String         @unique
  phone           String?
  role            UserRole       @default(student)
  joiningDate     DateTime?
  qualification   String?
  bloodGroup      String?
  gender          String?
  emergencyPhone  String?
  rollNo          String?
  class           String?
  section         String?
  fatherName      String?
  motherName      String?
  dob             DateTime?
  address         String?
  busNumber       String?
  busRoute        String?
  admissionDate   DateTime?
  profileColor    String?
  institutionId   String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  password        String
  isApproved      Boolean        @default(true)
  parentId        String?
  chatMemberships ChatMember[]
  chatMessages    ChatMessage[]
  refreshTokens   RefreshToken[]
  institution     Institution?   @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  parent          User?          @relation("ParentChildren", fields: [parentId], references: [id])
  children        User[]         @relation("ParentChildren")
  aiKey           UserAiKey?

  @@index([institutionId])
  @@index([institutionId, role])
  @@index([institutionId, class, section])
}

model GradebookEntry {
  id            String      @id @default(uuid())
  studentId     String
  studentName   String
  subject       String
  marks         Float
  examName      String
  date          DateTime
  remarks       String?
  institutionId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([institutionId])
  @@index([institutionId, studentId, date])
}

model DailyDiary {
  id            String      @id @default(uuid())
  classId       String
  className     String
  section       String
  subject       String
  teacherName   String
  classwork     String
  homework      String
  date          DateTime
  isPublished   Boolean     @default(false)
  institutionId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@index([institutionId, className, section, date])
}

model ParentMessage {
  id            String      @id @default(uuid())
  teacherId     String
  studentId     String
  parentName    String
  subject       String
  body          String
  category      String
  priority      String
  isBroadcast   Boolean     @default(false)
  classId       String?
  isRead        Boolean     @default(false)
  institutionId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([institutionId])
}

model SupportStaff {
  id            String      @id @default(uuid())
  name          String
  email         String
  phone         String
  role          String
  joiningDate   DateTime
  salary        Float
  isActive      Boolean     @default(true)
  busNumber     String?
  shift         String
  institutionId String
  createdAt     DateTime    @default(now())
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
}

model StaffPayroll {
  id            String      @id @default(uuid())
  staffId       String
  staffName     String
  role          String
  basicSalary   Float
  netSalary     Float
  month         String
  year          Int
  status        String
  paidOn        DateTime?
  paymentMethod String?
  institutionId String
  createdAt     DateTime    @default(now())
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@index([institutionId, year, month])
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Attendance {
  id            String      @id @default(uuid())
  userId        String
  date          DateTime
  status        String
  subject       String?
  className     String?
  section       String?
  notes         String?
  institutionId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@unique([institutionId, userId, date, subject])
  @@index([institutionId, date])
  @@index([institutionId, userId, date])
}

model FeeRecord {
  id            String      @id @default(uuid())
  studentId     String
  title         String
  amount        Float
  dueDate       DateTime
  paidDate      DateTime?
  status        String
  receiptNo     String?
  paymentMode   String?
  institutionId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId, studentId])
  @@index([institutionId, status, dueDate])
}

model TimetablePeriod {
  id            String      @id @default(uuid())
  dayOfWeek     Int
  periodNo      Int
  startTime     String
  endTime       String
  subject       String
  subjectCode   String?
  className     String
  section       String?
  room          String?
  teacherId     String?
  teacherName   String?
  institutionId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@unique([institutionId, className, section, dayOfWeek, periodNo])
  @@index([institutionId, teacherId])
}

model Notice {
  id            String      @id @default(uuid())
  title         String
  content       String
  publishedAt   DateTime    @default(now())
  authorId      String
  authorName    String
  priority      String      @default("medium")
  category      String      @default("General")
  audience      String      @default("all")
  institutionId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId, publishedAt])
}

model Exam {
  id            String      @id @default(uuid())
  title         String
  subject       String
  startsAt      DateTime
  durationMins  Int
  maxMarks      Float
  room          String?
  syllabus      String?
  className     String
  section       String?
  status        String      @default("scheduled")
  institutionId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId, className, section, startsAt])
}

model LeaveRequest {
  id            String      @id @default(uuid())
  userId        String
  fromDate      DateTime
  toDate        DateTime
  reason        String
  leaveType     String      @default("personal")
  status        String      @default("pending")
  reviewedBy    String?
  reviewRemarks String?
  reviewedAt    DateTime?
  institutionId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId, userId])
  @@index([institutionId, status])
}

model OnlineClass {
  id            String      @id @default(uuid())
  subject       String
  teacherId     String
  teacherName   String
  startsAt      DateTime
  durationMins  Int
  meetingUrl    String
  recordingUrl  String?
  status        String      @default("upcoming")
  className     String
  section       String?
  institutionId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId, className, section, startsAt])
  @@index([institutionId, teacherId])
}

model Assignment {
  id            String                 @id @default(uuid())
  title         String
  description   String
  subject       String
  className     String
  section       String?
  dueAt         DateTime
  maxMarks      Float
  status        String                 @default("active")
  teacherId     String
  institutionId String
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  institution   Institution            @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  submissions   AssignmentSubmission[]

  @@index([institutionId, className, section, dueAt])
  @@index([institutionId, teacherId])
}

model AssignmentSubmission {
  id           String     @id @default(uuid())
  assignmentId String
  studentId    String
  contentUrl   String?
  notes        String?
  marks        Float?
  feedback     String?
  submittedAt  DateTime   @default(now())
  gradedAt     DateTime?
  updatedAt    DateTime   @updatedAt
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([studentId])
}

model InstitutionSetting {
  id            String      @id @default(uuid())
  key           String
  value         String
  institutionId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@unique([institutionId, key])
  @@index([institutionId])
}

model SyllabusUnit {
  id             String      @id @default(uuid())
  subject        String
  subjectCode    String
  unitNo         Int
  unitTitle      String
  topics         String[]
  totalHours     Float
  completedHours Float
  status         String      @default("pending")
  institutionId  String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  institution    Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
}

model FeedbackSubmission {
  id            String      @id @default(uuid())
  targetType    String
  targetId      String
  targetName    String
  subjectName   String?
  rating        Int
  comment       String
  isAnonymous   Boolean     @default(false)
  studentId     String
  institutionId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@index([studentId])
}

model Doubt {
  id            String       @id @default(uuid())
  subjectCode   String
  subjectName   String
  title         String
  description   String
  askedBy       String
  status        String       @default("open")
  tags          String[]
  institutionId String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  institution   Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  replies       DoubtReply[]

  @@index([institutionId])
}

model DoubtReply {
  id            String      @id @default(uuid())
  doubtId       String
  authorName    String
  authorRole    String
  content       String
  isAccepted    Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  institutionId String
  doubt         Doubt       @relation(fields: [doubtId], references: [id], onDelete: Cascade)
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([doubtId])
  @@index([institutionId])
}

model OnlineExam {
  id            String        @id @default(uuid())
  title         String
  subject       String
  subjectCode   String
  durationMins  Int
  totalMarks    Float
  passingMarks  Float
  scheduledAt   DateTime
  status        String        @default("upcoming")
  institutionId String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  attempts      ExamAttempt[]
  questions     MCQQuestion[]
  institution   Institution   @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
}

model MCQQuestion {
  id            String      @id @default(uuid())
  examId        String
  question      String
  options       String[]
  correctIndex  Int
  marks         Float
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  institutionId String
  exam          OnlineExam  @relation(fields: [examId], references: [id], onDelete: Cascade)
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@index([institutionId])
}

model ExamAttempt {
  id            String      @id @default(uuid())
  examId        String
  studentId     String
  answers       Json
  score         Float
  passed        Boolean
  submittedAt   DateTime    @default(now())
  institutionId String
  createdAt     DateTime    @default(now())
  exam          OnlineExam  @relation(fields: [examId], references: [id], onDelete: Cascade)
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
  @@index([studentId])
  @@index([institutionId])
}

model AuditLog {
  id            String      @id @default(uuid())
  userId        String
  userName      String
  userRole      String
  action        String
  resource      String
  resourceId    String?
  details       Json?
  institutionId String
  timestamp     DateTime    @default(now())
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@index([userId])
}

model TransportRoute {
  id            String   @id @default(uuid())
  routeName     String
  vehicleNumber String
  driverName    String
  driverPhone   String
  stops         String[]
  institutionId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Vehicle {
  id            String   @id @default(uuid())
  number        String
  capacity      Int
  model         String
  institutionId String
  createdAt     DateTime @default(now())
}

model TransportAssignment {
  id            String   @id @default(uuid())
  userId        String
  routeId       String
  stopName      String
  monthlyFee    Float
  institutionId String
  createdAt     DateTime @default(now())
}

model LibraryBook {
  id            String   @id @default(uuid())
  title         String
  author        String
  isbn          String?
  totalCopies   Int
  available     Int
  institutionId String
  createdAt     DateTime @default(now())
}

model BookIssue {
  id            String    @id @default(uuid())
  bookId        String
  userId        String
  issueDate     DateTime  @default(now())
  dueDate       DateTime
  returnDate    DateTime?
  fineAmount    Float     @default(0)
  status        String    @default("issued")
  institutionId String
}

model Hostel {
  id            String   @id @default(uuid())
  name          String
  type          String
  wardenName    String
  institutionId String
  createdAt     DateTime @default(now())
}

model HostelRoom {
  id            String @id @default(uuid())
  hostelId      String
  roomNumber    String
  capacity      Int
  vacant        Int
  institutionId String
}

model HostelAllocation {
  id            String    @id @default(uuid())
  roomId        String
  userId        String
  joinDate      DateTime
  leaveDate     DateTime?
  monthlyFee    Float
  institutionId String
}

model FeeStructure {
  id            String   @id @default(uuid())
  batchName     String
  subject       String
  amount        Float
  frequency     String
  institutionId String
  createdAt     DateTime @default(now())
}

model StudyMaterial {
  id            String   @id @default(uuid())
  title         String
  description   String?
  fileUrl       String
  subject       String
  batchName     String?
  uploadedBy    String
  institutionId String
  createdAt     DateTime @default(now())
}

model Lead {
  id            String    @id @default(uuid())
  studentName   String
  phone         String
  email         String?
  source        String
  status        String    @default("new")
  interestedIn  String
  followUpDate  DateTime?
  institutionId String
  createdAt     DateTime  @default(now())
}

model SubjectEnrollment {
  id            String   @id @default(uuid())
  studentId     String
  subject       String
  teacherId     String
  enrollDate    DateTime
  status        String   @default("active")
  institutionId String
}

model HourlyBillingRecord {
  id            String   @id @default(uuid())
  studentId     String
  teacherId     String
  subject       String
  date          DateTime
  hours         Float
  ratePerHour   Float
  totalAmount   Float
  isBilled      Boolean  @default(false)
  institutionId String
  createdAt     DateTime @default(now())
}

model DemoClassBooking {
  id            String   @id @default(uuid())
  studentName   String
  phone         String
  subject       String
  scheduledAt   DateTime
  status        String   @default("scheduled")
  institutionId String
}

model Semester {
  id            String   @id @default(uuid())
  name          String
  startDate     DateTime
  endDate       DateTime
  status        String   @default("upcoming")
  institutionId String
}

model UniversityAffiliation {
  id             String   @id @default(uuid())
  universityName String
  affiliationNo  String
  validUntil     DateTime
  institutionId  String
}

model ElectiveCourse {
  id            String @id @default(uuid())
  courseCode    String
  courseName    String
  credits       Int
  maxStudents   Int
  enrolled      Int    @default(0)
  institutionId String
}

model ResearchThesis {
  id             String    @id @default(uuid())
  studentId      String
  title          String
  supervisorId   String
  status         String    @default("proposed")
  submissionDate DateTime?
  institutionId  String
}

model Alumnus {
  id            String  @id @default(uuid())
  userId        String
  passoutYear   Int
  currentJob    String?
  company       String?
  institutionId String
}

model IntegrationConfig {
  id            String      @id @default(uuid())
  institutionId String
  provider      String
  encryptedData String
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@unique([institutionId, provider])
  @@index([institutionId])
}

model NotificationLog {
  id            String      @id @default(uuid())
  institutionId String
  channel       String
  recipient     String
  message       String
  status        String      @default("pending")
  provider      String
  errorMessage  String?
  sentAt        DateTime    @default(now())
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@index([sentAt])
}

model PaymentRecord {
  id               String      @id @default(uuid())
  institutionId    String
  studentId        String
  feeRecordId      String?
  gateway          String
  gatewayOrderId   String
  gatewayPaymentId String?
  amount           Float
  currency         String      @default("INR")
  status           String      @default("created")
  webhookVerified  Boolean     @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  institution      Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
  @@index([studentId])
  @@index([gatewayOrderId])
}

model ChatRoom {
  id            String        @id @default(uuid())
  institutionId String
  type          String        @default("direct")
  name          String?
  createdAt     DateTime      @default(now())
  members       ChatMember[]
  messages      ChatMessage[]
  institution   Institution   @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
}

model ChatMember {
  id       String   @id @default(uuid())
  roomId   String
  userId   String
  joinedAt DateTime @default(now())
  room     ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([userId])
}

model ChatMessage {
  id        String   @id @default(uuid())
  roomId    String
  senderId  String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([senderId])
  @@index([createdAt])
}

model UserAiKey {
  id           String   @id @default(uuid())
  userId       String   @unique
  provider     String
  encryptedKey String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum InstitutionType {
  school
  coaching
  online_teaching
  college
  tuition
  hybrid
}

enum UserRole {
  superadmin
  school_admin
  teacher
  student
  parent
}
